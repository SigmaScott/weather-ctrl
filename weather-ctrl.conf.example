[remote]
# IP address or hostname of the remote device
host = 192.168.1.100
# TCP port (default: 5555)
port = 5555
# Delay in seconds between commands sent to device (default: 3)
cmd_delay = 3

[timer]
# Duration in seconds for passthrough mode (P function)
duration = 300

[logging]
# Log file path (optional, defaults to ./weather-ctrl.log)
# file = /var/log/weather-ctrl.log

[ratelimit]
# Maximum number of P calls per port within the time window
max_calls = 5
# Time window in seconds for rate limiting
window_seconds = 60
